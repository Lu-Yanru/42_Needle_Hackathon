{
  "name": "needle-agent",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "better-result": "^2.9.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@orpc/server": "^1.13.14",
      "@orpc/openapi": "^1.13.14",
      "@orpc/zod": "^1.13.14",
      "better-auth": "1.6.11",
      "next-themes": "^0.4.6",
      "@orpc/client": "^1.13.14",
      "@types/react-dom": "^19.2.3",
      "ai": "^6.0.190",
      "@openrouter/ai-sdk-provider": "^2.9.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "tui": "bun run apps/tui/src/main.tsx",
    "db:push": "turbo run db:push --filter=@needle-agent/db",
    "db:studio": "turbo run db:studio --filter=@needle-agent/db",
    "db:generate": "turbo run db:generate --filter=@needle-agent/db",
    "db:migrate": "turbo run db:migrate --filter=@needle-agent/db",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@needle-agent/env": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@needle-agent/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "overrides": {
    "@types/react": "19.2.15"
  },
  "packageManager": "bun@1.3.13"
}
