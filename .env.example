# Copy to .env and fill in. .env is gitignored.
#
# OpenRouter API key — required by the agent harness (apps/agent) and the
# Operator Console's live-preview feature. Create one at:
#   https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional agent overrides — see apps/agent/src/config.ts for defaults.
# AGENT_MODEL=openai/gpt-oss-120b
# AGENT_REASONING_EFFORT=medium   # low | medium | high
# AGENT_TEMPERATURE=0.1
# AGENT_TIMEOUT_MS=180000
# AGENT_MAX_ITER=40
