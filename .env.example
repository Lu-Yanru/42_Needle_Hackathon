# Single source of truth for the whole monorepo. Copy to .env (gitignored).
# Every app loads this root file:
#   - apps/agent, apps/server : bun --env-file ../../.env
#   - apps/web (Vite)         : envDir "../.." in vite.config.ts

# --- Model / agent (apps/agent + Operator Console) ---
# OpenRouter API key — required. Create one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional agent overrides — see apps/agent/src/config.ts for defaults.
# AGENT_MODEL=openai/gpt-oss-120b
# AGENT_REASONING_EFFORT=medium   # low | medium | high
# AGENT_TEMPERATURE=0.1
# AGENT_TIMEOUT_MS=180000
# AGENT_MAX_ITER=40
# AGENT_TEAM_NAME=

# --- Server (apps/server) ---
DATABASE_URL=
BETTER_AUTH_SECRET=          # at least 32 characters
BETTER_AUTH_URL=             # e.g. http://localhost:3000
CORS_ORIGIN=                 # e.g. http://localhost:3001
# NODE_ENV=development

# --- Web (apps/web) ---
VITE_SERVER_URL=             # e.g. http://localhost:3000
